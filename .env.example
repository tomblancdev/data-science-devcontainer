# Copy to `.env` (git-ignored) — loaded into the container by compose.yaml.
# Use for non-secret config and local dev values.

# Example: where notebooks/scripts look for data
DATA_DIR=./data

# Note: service ports (8888/2718/8501) are forwarded dynamically by VS Code
# (see `forwardPorts` in devcontainer.json), which auto-resolves host-port
# conflicts — so there's nothing to configure here for ports.

# Example: a connection string for the `db` extra
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# For real secrets, prefer compose `secrets:` (mounted at /run/secrets/<name>)
# over committing them anywhere near the repo.
