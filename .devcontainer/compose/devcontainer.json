// OPTIONAL Compose variant of the dev container.
// The DEFAULT (../devcontainer.json) is Dockerfile-based and needs no Compose —
// prefer it unless you specifically want compose-managed secrets or extra
// services. Runtime (build, mounts, env, secrets) lives in ../compose.yaml.
//
// Rootless Podman: add the override ->
//   "dockerComposeFile": ["../compose.yaml", "../compose.podman.yaml"]
{
  "name": "Data Science (Compose) (uv · ruff · polars · duckdb)",

  "dockerComposeFile": ["../compose.yaml"],
  "service": "app",
  "workspaceFolder": "/workspaces/data-science",

  // Respect `command: sleep infinity` from compose instead of overriding it.
  "overrideCommand": false,

  // Stop the compose project when the window closes (no lingering containers).
  "shutdownAction": "stopCompose",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "username": "vscode"
    },
    "ghcr.io/guiyomh/features/just:0": {}
  },

  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  "forwardPorts": [8888, 2718, 8501],
  "portsAttributes": {
    "8888": { "label": "JupyterLab", "onAutoForward": "notify" },
    "2718": { "label": "marimo", "onAutoForward": "notify" },
    "8501": { "label": "Streamlit", "onAutoForward": "silent" }
  },

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        // --- Python core ---
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "KevinRose.vsc-python-indent",
        "njpwerner.autodocstring",

        // --- Ruff: lint + format in Rust (replaces black/flake8/isort/pylint) ---
        "charliermarsh.ruff",

        // --- Notebooks ---
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",

        // --- Interactive data exploration (point-and-click on a DataFrame) ---
        "ms-toolsai.datawrangler",

        // --- Tabular / SQL viewers ---
        "mechatroner.rainbow-csv",
        "GrapeCity.gc-excelviewer",
        "mtxr.sqltools",

        // --- Config formats ---
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "editorconfig.editorconfig",

        // --- Git + quality of life ---
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",

        // --- Icon suite ---
        "PKief.material-icon-theme"
      ],

      "settings": {
        "workbench.iconTheme": "material-icon-theme",
        "terminal.integrated.defaultProfile.linux": "zsh",

        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "ruff.importStrategy": "fromEnvironment",

        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.venvFolders": ["/home/vscode"],
        "python.terminal.activateEnvironment": false,
        "python.testing.pytestEnabled": true,
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.inlayHints.functionReturnTypes": true,
        "python.analysis.inlayHints.variableTypes": true,

        "notebook.formatOnSave.enabled": true,
        "notebook.defaultFormatter": "charliermarsh.ruff",
        "notebook.codeActionsOnSave": {
          "notebook.source.fixAll.ruff": "explicit",
          "notebook.source.organizeImports.ruff": "explicit"
        },
        "notebook.lineNumbers": "on",
        "notebook.output.textLineLimit": 60,
        "jupyter.askForKernelRestart": false,

        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/.ruff_cache": true,
          "**/.mypy_cache": true,
          "**/.ipynb_checkpoints": true
        }
      }
    }
  }
}
